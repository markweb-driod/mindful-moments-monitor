# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# Optional aliases accepted by server auth middleware:
# SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"

# Vite client-side Supabase vars
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Gemini
GEMINI_API_KEY="your-gemini-api-key"
# Optional aliases accepted by AI server function:
# GOOGLE_API_KEY="your-gemini-api-key"
# GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"
# Optional override
# GEMINI_MODEL="gemini-2.5-flash"

# Firebase Admin (server-side persistence/history; optional during migration)
# Preferred: provide full JSON in one variable
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Or base64-encoded JSON:
# FIREBASE_SERVICE_ACCOUNT_BASE64="base64-encoded-service-account-json"
# Or split fields:
# FIREBASE_PROJECT_ID="your-firebase-project-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client (browser authentication)
# VITE_FIREBASE_API_KEY="your-firebase-web-api-key"
# VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
# VITE_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"
# Optional:
# VITE_FIREBASE_MESSAGING_SENDER_ID="1234567890"
# VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
